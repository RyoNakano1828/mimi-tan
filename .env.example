# Gemini API Key (例文生成に使用)
GEMINI_API_KEY=your-gemini-api-key

# 使用モデル（省略時: gemini-2.5-flash-lite）
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Google Cloud TTS (音声生成) ---

# 【ローカル開発・推奨】JSONキーファイルのパスを指定
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# GOOGLE_APPLICATION_CREDENTIALS_JSON は Vercel 向け（1行 JSON または Base64）
# ローカルで複数行 JSON を .env に書くと読み込みに失敗します
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
