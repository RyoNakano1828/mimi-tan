# Gemini API Key (例文生成に使用)
GEMINI_API_KEY=your-gemini-api-key

# 使用モデル（省略時: gemini-2.5-flash-lite）
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Google Cloud TTS (音声生成) ---

# 【ローカル開発】JSONキーファイルのパスを指定
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# 【Vercel デプロイ】JSONの中身をそのまま貼り付け（推奨）
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# 【Vercel デプロイ】Base64エンコードしたJSONでも可
# GOOGLE_APPLICATION_CREDENTIALS_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
